APP_ENV=local

POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=mhc_cloud_panel
POSTGRES_USER=mhc
POSTGRES_PASSWORD=mhc

REDIS_URL=redis://redis:6379/0

BACKEND_PORT=8000
FRONTEND_PORT=3000
API_BASE_URL=http://backend:8000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_PROXMOX_HOST=localhost
COOKIE_SECURE=false

JWT_SECRET=change-me
JWT_ACCESS_TOKEN_EXPIRES_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRES_DAYS=30
JWT_ISSUER=mhc-cloud-panel

CORS_ORIGINS=http://localhost:3000

SEED_ON_STARTUP=true

# Para usar o mock da API, deixe assim. Para real, mude para seu IP do Proxmox
PROXMOX_HOST=http://proxmox_mock:8001
PROXMOX_USER=mock
PROXMOX_REALM=pam
PROXMOX_TOKEN_NAME=mock
PROXMOX_TOKEN_SECRET=mock
PROXMOX_VERIFY_SSL=false
PROXMOX_TIMEOUT_SECONDS=15
PROXMOX_RETRY_TOTAL=3

# NodeScheduler — node selection for VM provisioning (ProxLB-inspired)
# Method to rank nodes: memory | cpu | disk
SCHEDULER_METHOD=memory
# Reserve buffer (%): won't use last N% of node RAM when selecting
SCHEDULER_RESERVE_PCT=10

# Cluster rebalancing (Celery Beat periodic task)
# Delta (%) threshold between most/least loaded node to trigger rebalancing
REBALANCE_THRESHOLD_PCT=20
# Set to true to actually migrate VMs; false = dry-run (log only)
REBALANCE_ENABLED=false
