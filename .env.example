APP_ENV=local

POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=mhc_cloud_panel
POSTGRES_USER=mhc
POSTGRES_PASSWORD=mhc

REDIS_URL=redis://redis:6379/0

BACKEND_PORT=8000
FRONTEND_PORT=3000
API_BASE_URL=http://backend:8000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_PROXMOX_HOST=localhost
COOKIE_SECURE=false

JWT_SECRET=change-me
JWT_ACCESS_TOKEN_EXPIRES_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRES_DAYS=30
JWT_ISSUER=mhc-cloud-panel

CORS_ORIGINS=http://localhost:3000

SEED_ON_STARTUP=true

# --- Proxmox ---
# Mock (padrão para desenvolvimento sem cluster real):
PROXMOX_HOST=http://proxmox_mock:8001
PROXMOX_USER=mock
PROXMOX_REALM=pam
PROXMOX_TOKEN_NAME=mock
PROXMOX_TOKEN_SECRET=mock
PROXMOX_VERIFY_SSL=false
PROXMOX_TIMEOUT_SECONDS=30
PROXMOX_RETRY_TOTAL=3

# Proxmox real (exemplos):
# Servidor/VM dedicada:
#   PROXMOX_HOST=https://192.168.1.10:8006
# Proxmox instalado no Debian WSL2 (com netsh portproxy ativo no Windows):
#   PROXMOX_HOST=https://host.docker.internal:8006

# --- NodeScheduler (seleção de node para provisionamento) ---
# Método de ranking: memory | cpu | disk
SCHEDULER_METHOD=memory
# Buffer (%): não usa os últimos N% de RAM do node ao selecionar
SCHEDULER_RESERVE_PCT=10

# --- Rebalanceamento de cluster (Celery Beat, a cada 30 min) ---
# Delta (%) entre node mais/menos carregado para disparar rebalanceamento
REBALANCE_THRESHOLD_PCT=20
# false = dry-run (apenas loga, não migra VMs)
REBALANCE_ENABLED=false
